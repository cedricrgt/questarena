@startuml architecture_diagram

' --- Style moderne (couleurs CSS QuestsArena) ---
skinparam shadowing false
skinparam roundCorner 15
skinparam defaultFontName "Raleway, sans-serif"

skinparam rectangle {
    BackgroundColor transparent
    BorderColor #4a2040
    BorderThickness 2
    FontColor #4a2040
    FontSize 16
    FontStyle bold
}

skinparam component {
    BackgroundColor #e5fcff
    BorderColor #a96fff
    ArrowColor #e9b872
    FontColor #0e060c
}

skinparam database {
    BackgroundColor #a96fff
    BorderColor #4a2040
    FontColor #0e060c
}

skinparam node {
    BackgroundColor transparent
    BorderColor #4a2040
    FontColor #4a2040
}
' --------------------------------------------

rectangle "Frontend" {
  [React] as react
  [Tailwind CSS] as tailwind
  [React Router] as react_router
  [React Query] as react_query
  [Axios] as axios
}

rectangle "Backend" {
  [NestJS] as nestjs
  [Prisma] as prisma
  [Swagger] as swagger
  [JWT] as jwt
  [Express] as express
}

database "PostgreSQL" as postgres

rectangle "Outils de Développement" {
  [Docker] as docker
  [Git & GitHub] as git
}

react --> axios: Requêtes API
axios --> nestjs: Appels HTTP
nestjs --> express: Gestion des routes
nestjs --> prisma: Accès à la base de données
prisma --> postgres: Requêtes SQL
nestjs --> swagger: Documentation API
nestjs --> jwt: Authentification
docker --> react: Conteneurisation
docker --> nestjs: Conteneurisation
git --> react: Gestion de versions
git --> nestjs: Gestion de versions

@enduml
